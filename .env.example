# Copia este fichero a `.env` y rellena los valores. `.env` está en .gitignore.
# En Kubernetes estas variables llegarán vía Secret, no vía fichero.

# --- Postgres (decisión #1: Neon como fuente de verdad) ---
# Neon:  postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/sentinel?sslmode=require
# Local: postgresql://sentinel:sentinel@localhost:5432/sentinel   (docker-compose.dev.yml)
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel

# --- FRED (ingestor macro, más adelante en fase 1) ---
# Key gratuita: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Telegram (fase 6) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Grafana (fase 5) ---
# Contraseña del admin de la UI (usuario: admin).
GRAFANA_ADMIN_PASSWORD=

# Conexión de Grafana a la BD con rol de SOLO LECTURA (decisión 5.3: mínimo
# privilegio — el visor no puede romper lo que enseña). El rol se crea UNA VEZ
# por base con este SQL (como owner; la password no puede ir en una migración
# porque las migraciones van a Git):
#
#   CREATE ROLE grafana_ro LOGIN PASSWORD '<genera-una>';
#   GRANT USAGE ON SCHEMA gold, silver, bronze TO grafana_ro;
#   GRANT SELECT ON ALL TABLES IN SCHEMA gold, silver, bronze TO grafana_ro;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA gold, silver, bronze
#       GRANT SELECT ON TABLES TO grafana_ro;   -- las vistas futuras heredan solas
# (bronze incluido: el dashboard de operación lee el log de fetches — hallazgo
#  del smoke test 2026-07-07; sigue siendo solo-lectura.)
#
# GRAFANA_DB_HOST lleva host:puerto (sin esquema ni credenciales).
# Neon:  ep-xxxx.eu-central-1.aws.neon.tech:5432   /  Local: localhost:5432
GRAFANA_DB_HOST=localhost:5432
GRAFANA_DB_NAME=sentinel
GRAFANA_DB_USER=grafana_ro
GRAFANA_DB_PASSWORD=
# require para Neon (exige TLS) · disable para el Postgres local del compose
GRAFANA_DB_SSLMODE=require
