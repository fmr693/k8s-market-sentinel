{
  "title": "CEF Sentinel",
  "uid": "cef-sentinel",
  "description": "Business dashboard: CEF premiums/discounts, z-scores and macro traffic lights. Data is informational only; intraday discounts are ESTIMATES (yesterday's NAV). Not investment advice.",
  "tags": [
    "sentinel",
    "business"
  ],
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "time": {
    "from": "now-1y",
    "to": "now"
  },
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HY credit spread (ICE BofA OAS)",
      "description": "Extra yield that high-yield ('junk') corporate bonds pay over US Treasuries. THE credit-stress thermometer: widening = fear and falling bond prices (the buying window for credit CEFs may be opening); tight = calm/complacency. Note: FRED's API only serves the last ~3 years (ICE licence limit).",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "neon-sentinel"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT obs_date::timestamptz AS \"time\", value FROM silver.macro_series WHERE series_id = 'BAMLH0A0HYM2' ORDER BY 1"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 4.5
              },
              {
                "color": "red",
                "value": 6
              }
            ]
          }
        },
        "overrides": []
      }
    },
